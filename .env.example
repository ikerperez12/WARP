# Contact API delivery setup (/api/contact)
# REQUIRED: primary inbox used by FormSubmit fallback and default Resend recipient.
CONTACT_RECIPIENT_EMAIL=you@example.com

# OPTIONAL: if configured, Resend is tried first.
RESEND_API_KEY=

# OPTIONAL: verified sender for Resend.
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# OPTIONAL: additional Resend recipients (comma-separated).
# If empty, CONTACT_RECIPIENT_EMAIL is used.
CONTACT_TO_EMAILS=
